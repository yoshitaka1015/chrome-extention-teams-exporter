{
  "manifest_version": 3,
  "name": "Teams Chat Exporter",
  "version": "1.0.0",
  "description": "Microsoft Teams のチャット・チャネルからメッセージをエクスポート",
  "permissions": ["activeTab", "downloads"],
  "host_permissions": ["https://teams.microsoft.com/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://teams.microsoft.com/*"],
      "js": [
        "content/selectors.js",
        "content/parser.js",
        "content/scroller.js",
        "content/formatter.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
